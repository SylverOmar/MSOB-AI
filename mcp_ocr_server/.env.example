# Copy this file to .env on the machine that hosts the MCP service.
# Keep real Groq keys only in .env. Do not commit them.
GROQ_API_KEY=
GROQ_FALLBACK_API_KEY=
GROQ_VISION_MODEL=
MCP_HOST=0.0.0.0
MCP_PORT=8002
MCP_MAX_FILE_BYTES=26214400
MCP_QUEUE_TTL_SECONDS=21600
MCP_LOG_LEVEL=INFO
MCP_BROWSER_ORIGINS=https://msob-ai.vercel.app
MCP_PUBLIC_URL=https://your-reserved-domain.ngrok-free.dev
